# ─── Single root env, read by docker-compose (and local runs) ─────────────────
# In Docker, DATABASE_URL/REDIS_URL are overridden to point at service names;
# the values below are used for local (non-Docker) runs.

# Database / cache
DATABASE_URL=
REDIS_URL=

# OpenAI
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
INTENT_MODEL=gpt-4o-mini
SYNTHESIS_MODEL=gpt-4o-mini

# Data layout for ingestion:  {DATA_DIR}/{city}/{listings,calendar,reviews}.csv[.gz]
# Files may be gzipped (.csv.gz) or already decompressed (.csv).
DATA_DIR=./data
CITIES=lisbon,barcelona

# Ingestion tuning
CALENDAR_DAYS=7
MAX_REVIEWS_PER_LISTING=40
DETECT_LANGUAGE=true
EMBED_BATCH_SIZE=256
SUMMARY_MIN_REVIEWS=3
SUMMARY_REVIEWS_PER_PROMPT=20
SUMMARY_CONCURRENCY=8
# Cost guardrail. 0 = summarize every eligible listing (~$15-50, 1-3h at full
# two-city scale). Set e.g. 2000 for a bounded demo run that prioritizes the
# most-reviewed listings.
SUMMARY_MAX_LISTINGS=2000

# API tuning
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
CACHE_TTL_SECONDS=3600
RETRIEVAL_LIMIT=24
TAX_RATE=0.10
CLEANING_FEE=45
